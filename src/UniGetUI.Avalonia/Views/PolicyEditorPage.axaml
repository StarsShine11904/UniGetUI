<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="UniGetUI.Avalonia.Views.PolicyEditorPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20" ColumnDefinitions="1.5*,1*" RowDefinitions="Auto,Auto,Auto,Auto">

            <Border Grid.Column="0" Grid.ColumnSpan="2" Padding="0,0,0,8">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Policy Editor" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="POC editor for UniGetUI elevation policies using the new normalized package schema"
                                   FontSize="13" Opacity="0.55" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="NewPolicyButton" Content="New" Click="NewPolicy_Click" />
                        <Button x:Name="OpenPolicyButton" Content="Open" Click="OpenPolicy_Click" />
                        <Button x:Name="SavePolicyButton" Content="Save" Click="SavePolicy_Click" Classes="accent" />
                        <Button x:Name="SaveAsPolicyButton" Content="Save as" Click="SaveAsPolicy_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,8,0">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="Metadata" FontSize="16" FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Policy ID" FontSize="12" Opacity="0.7" />
                            <TextBox x:Name="PolicyIdTextBox" TextChanged="Metadata_Changed" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                                <TextBlock Text="Kind" FontSize="12" Opacity="0.7" />
                                <TextBox x:Name="KindTextBox" IsReadOnly="True" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                                <TextBlock Text="Schema version" FontSize="12" Opacity="0.7" />
                                <TextBox x:Name="SchemaVersionTextBox" IsReadOnly="True" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="Defaults" FontSize="16" FontWeight="SemiBold" />
                        <CheckBox x:Name="DefaultInstallCheckBox" Content="Allow install operations"
                                  IsChecked="True" IsCheckedChanged="Defaults_Changed" />
                        <CheckBox x:Name="DefaultUpdateCheckBox" Content="Allow update operations"
                                  IsChecked="True" IsCheckedChanged="Defaults_Changed" />
                        <CheckBox x:Name="AllowAnyVersionCheckBox" Content="Allow any version"
                                  IsChecked="True" IsCheckedChanged="Defaults_Changed" />
                        <CheckBox x:Name="CaseSensitiveIdCheckBox" Content="Case-sensitive package IDs"
                                  IsCheckedChanged="Defaults_Changed" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0" Spacing="4">
                        <TextBlock Text="Generated by" FontSize="12" Opacity="0.7" />
                        <TextBox x:Name="GeneratedByTextBox" IsReadOnly="True" />
                    </StackPanel>

                    <TextBlock x:Name="EditorStatusText" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                               Margin="0,12,0,0" FontSize="12" Opacity="0.55" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16" Margin="8,0,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="Summary" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock x:Name="SummaryFileText" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    <TextBlock x:Name="SummaryPackagesText" FontSize="12" Opacity="0.7" />
                    <TextBlock x:Name="SummaryCallersText" FontSize="12" Opacity="0.7" />
                    <TextBlock x:Name="SummaryTimestampText" FontSize="12" Opacity="0.7" />
                    <Button x:Name="ImportBundleButton" Content="Import UniGetUI bundle"
                            Click="ImportBundle_Click" Classes="accent" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,16,8,0">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Packages" FontSize="16" FontWeight="SemiBold" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ClearPackageFormButton" Content="Clear form" Click="ClearPackageForm_Click" />
                            <Button x:Name="RemovePackagesButton" Content="Remove selected" Click="RemoveSelectedPackages_Click" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="150,*,180,Auto,Auto,Auto" Margin="0,12,0,0">
                        <ComboBox x:Name="ManagerComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="winget" />
                            <ComboBoxItem Content="scoop" />
                            <ComboBoxItem Content="chocolatey" />
                            <ComboBoxItem Content="npm" />
                            <ComboBoxItem Content="pip" />
                            <ComboBoxItem Content="powershell" />
                            <ComboBoxItem Content="powershell7" />
                            <ComboBoxItem Content="dotnettool" />
                            <ComboBoxItem Content="cargo" />
                            <ComboBoxItem Content="vcpkg" />
                            <ComboBoxItem Content="homebrew" />
                        </ComboBox>
                        <TextBox x:Name="PackageIdTextBox" Grid.Column="1" Watermark="Package ID" Margin="8,0,0,0" />
                        <TextBox x:Name="PackageSourceTextBox" Grid.Column="2" Watermark="Source (optional)" Margin="8,0,0,0" />
                        <CheckBox x:Name="PackageInstallCheckBox" Grid.Column="3" Content="Install" IsChecked="True" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <CheckBox x:Name="PackageUpdateCheckBox" Grid.Column="4" Content="Update" IsChecked="True" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <Button x:Name="SavePackageButton" Grid.Column="5" Content="Add / update" Click="SavePackage_Click" Classes="accent" Margin="8,0,0,0" />
                    </Grid>

                    <DataGrid x:Name="PackagesGrid" Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              SelectionMode="Extended"
                              IsReadOnly="True"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              RowHeight="34"
                              Margin="0,12,0,0"
                              SelectionChanged="PackagesGrid_SelectionChanged" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="1"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16" Margin="8,16,0,0">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Trusted callers" FontSize="16" FontWeight="SemiBold" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="BrowseCallerButton" Content="Browse" Click="BrowseCaller_Click" />
                            <Button x:Name="RemoveCallerButton" Content="Remove selected" Click="RemoveSelectedCallers_Click" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <TextBox x:Name="CallerPathTextBox" Watermark="Trusted caller path" />
                        <CheckBox x:Name="CallerSignatureCheckBox" Grid.Column="1" Content="Signature required" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <Button x:Name="SaveCallerButton" Grid.Column="2" Content="Add / update" Click="SaveCaller_Click" Classes="accent" Margin="8,0,0,0" />
                    </Grid>

                    <DataGrid x:Name="TrustedCallersGrid" Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="False"
                              SelectionMode="Extended"
                              IsReadOnly="True"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              RowHeight="34"
                              Margin="0,12,0,0"
                              SelectionChanged="TrustedCallersGrid_SelectionChanged" />
                </Grid>
            </Border>

            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,16,0,0">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="JSON preview" FontSize="16" FontWeight="SemiBold" />
                        <Button Grid.Column="1" Content="Refresh preview" Click="RefreshPreview_Click" />
                    </Grid>
                    <TextBox x:Name="JsonPreviewTextBox"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             FontFamily="Cascadia Code,Consolas,monospace"
                             MinHeight="280" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
